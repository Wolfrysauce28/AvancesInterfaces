---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthGuard from '../components/common/AuthGuard';
import AdminDashboard from '../components/admin/AdminDashboard';
import ThemeToggle from '../components/common/ThemeToggle';
---

<BaseLayout title="Panel KDS - FoodSave" viewId="admin" description="Panel de administración de inventario KDS para gestionar packs de comida y reducir merma.">
  <main id="app" class="w-full transition-all duration-300">
    <AuthGuard requiredRole="admin" client:idle>
      <AdminDashboard client:idle />
    </AuthGuard>
  </main>
  <ThemeToggle client:idle />
</BaseLayout>
