---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthGuard from '../components/common/AuthGuard';
import ClientDashboard from '../components/client/ClientDashboard';
import ThemeToggle from '../components/common/ThemeToggle';
---

<BaseLayout title="Portal de Rescate - FoodSave" viewId="home" description="Explora packs sorpresa con descuentos de hasta 70% en restaurantes y tiendas cerca de ti.">
  <main id="app" class="w-full transition-all duration-300">
    <AuthGuard requiredRole="client" client:load>
      <ClientDashboard client:load />
    </AuthGuard>
  </main>
  <ThemeToggle client:idle />
</BaseLayout>
